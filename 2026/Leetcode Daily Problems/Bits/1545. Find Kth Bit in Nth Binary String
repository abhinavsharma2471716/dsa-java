Given two positive integers n and k, the binary string Sn is formed as follows:

S1 = "0"
Si = Si - 1 + "1" + reverse(invert(Si - 1)) for i > 1
Where + denotes the concatenation operation, reverse(x) returns the reversed string x, and invert(x) inverts all the bits in x (0 changes to 1 and 1 changes to 0).

For example, the first four strings in the above sequence are:

S1 = "0"
S2 = "011"
S3 = "0111001"
S4 = "011100110110001"
Return the kth bit in Sn. It is guaranteed that k is valid for the given n.

 

Example 1:

Input: n = 3, k = 1
Output: "0"
Explanation: S3 is "0111001".
The 1st bit is "0".
Example 2:

Input: n = 4, k = 11
Output: "1"
Explanation: S4 is "011100110110001".
The 11th bit is "1".
 

Constraints:

1 <= n <= 20
1 <= k <= 2^n - 1

Code: 

Approach 1 : //O(2^n)

class Solution {
    public char findKthBit(int n, int k) {
        if (k == 1) {
            return '0';
        }
        StringBuilder sb = new StringBuilder();
        sb.append('0');
        for (int i = 1; i < n; i++) {
            StringBuilder csb = new StringBuilder();
            for (int j = 0; j < sb.length(); j++) {
                if (sb.charAt(j) == '1') {
                    csb.append('0');
                } else {
                    csb.append('1');
                }
            }
            sb.append('1');
            sb.append(csb.reverse());

            if (sb.length() >= k) {
                return sb.charAt(k - 1);
            }
        }
        return '0';
    }
}



Approach 2 : //O(n)

class Solution {
    public char findKthBit(int n, int k) {
        // Base case: S_1 is "0"
        if (n == 1) {
            return '0';
        }

        // Length of the string S_n is 2^n - 1
        int length = (1 << n) - 1;
        int mid = length / 2 + 1;  // Middle index (1-based)

        // If k is the middle element, it's '1'
        if (k == mid) {
            return '1';
        }

        // If k is in the first half, it's the same as in S_{n-1}
        if (k < mid) {
            return findKthBit(n - 1, k);
        }

        // If k is in the second half, it corresponds to the reverse and inverted bit
        // in S_{n-1}. The corresponding index is `length - k + 1`.
        char invertedBit = findKthBit(n - 1, length - k + 1);

        // Invert the bit: '0' becomes '1' and '1' becomes '0'
        return invertedBit == '0' ? '1' : '0';
    }
}

 
